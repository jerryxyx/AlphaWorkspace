<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.mihomo.root</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/mihomo</string>
        <string>-d</string>
        <string>/Users/xyx/.config/mihomo</string>
        <string>-f</string>
        <string>/Users/xyx/.config/mihomo/config.yaml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/xyx/.config/mihomo/mihomo.root.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/xyx/.config/mihomo/mihomo.root.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>